 {
  "family": "streamiq-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "your-dockerhub-username/streamiq-backend:latest",
      "essential": true,
      "portMappings": [
        { "containerPort": 8000, "hostPort": 8000 }
      ],
      "environment": [
        { "name": "NLP_ENGINE", "value": "hf" },
        { "name": "DB_HOST", "value": "db" },
        { "name": "DB_PORT", "value": "3306" },
        { "name": "DB_USER", "value": "root" },
        { "name": "DB_PASSWORD", "value": "root" },
        { "name": "DB_NAME", "value": "streamiq" }
      ]
    },
    {
      "name": "dashboard",
      "image": "your-dockerhub-username/streamiq-dashboard:latest",
      "essential": true,
      "portMappings": [
        { "containerPort": 8501, "hostPort": 8501 }
      ],
      "environment": [
        { "name": "BACKEND_URL", "value": "http://backend:8000" }
      ]
    },
    {
      "name": "db",
      "image": "mysql:8.0",
      "essential": true,
      "portMappings": [
        { "containerPort": 3306, "hostPort": 3306 }
      ],
      "environment": [
        { "name": "MYSQL_ROOT_PASSWORD", "value": "root" },
        { "name": "MYSQL_DATABASE", "value": "streamiq" }
      ]
    }
  ]
}
